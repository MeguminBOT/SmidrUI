<?xml version="1.0" encoding="utf-8"?>
<project>
	<meta title="SmiðrUI Flixel Example" package="com.meguminbot.smidr.flixel" version="0.1.0" company="MeguminBOT" />

	<!--
		The smidr.flixel bridge on a HaxeFlixel state (needs the flixel haxelib). Build from the
		repo root:
		  lime test examples/flixel/project.xml windows
		  lime build examples/flixel/project.xml html5      (static web build -> bin/html5/bin)
		Swap `windows` for `mac`, `linux`, `html5`, `hl`, etc.
	-->
	<app main="FlixelExample" file="FlixelExample" path="bin" />
	<window width="960" height="600" fps="60" background="#121214" vsync="true" resizable="true" />

	<source path="../../src" />
	<source path="." />

	<haxelib name="openfl" />
	<haxelib name="flixel" />
	<haxedef name="flixel" />

	<!-- optional embedded font (falls back to a default font when absent); build with -Dassets -->
	<assets path="../assets" rename="assets" if="assets" />
</project>
