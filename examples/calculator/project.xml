<?xml version="1.0" encoding="utf-8"?>
<project>
	<meta title="SmiðrUI Calculator" package="com.meguminbot.smidr.calculator" version="0.1.0" company="MeguminBOT" />

	<!--
		A standalone four-function calculator app. Build from the repo root:
		  lime test examples/calculator/project.xml windows
		  lime build examples/calculator/project.xml html5    (static web build -> bin/html5/bin)
		Swap `windows` for `mac`, `linux`, `html5`, `hl`, etc.
	-->
	<app main="Calculator" file="Calculator" path="bin" />
	<window width="320" height="470" fps="60" background="#121214" vsync="true" resizable="false" />

	<source path="../../src" />
	<source path="." />

	<haxelib name="openfl" />

	<!-- optional embedded font (falls back to a default font when absent); build with -Dassets -->
	<assets path="../assets" rename="assets" if="assets" />
</project>
