<?xml version="1.0" encoding="utf-8"?>
<project>
	<meta title="SmiðrUI Full Example" package="com.meguminbot.smidr.full" version="0.1.0" company="MeguminBOT" />

	<!--
		A broader layout wiring many widgets together. Build from the repo root:
		  lime test examples/full/project.xml windows
		  lime build examples/full/project.xml html5        (static web build -> bin/html5/bin)
		Swap `windows` for `mac`, `linux`, `html5`, `hl`, etc.
	-->
	<app main="FullExample" file="FullExample" path="bin" />
	<window width="960" height="600" fps="60" background="#121214" vsync="true" resizable="true" />

	<source path="../../src" />
	<source path="." />

	<haxelib name="openfl" />

	<!-- optional embedded font (falls back to a default font when absent); build with -Dassets -->
	<assets path="../assets" rename="assets" if="assets" />
</project>
