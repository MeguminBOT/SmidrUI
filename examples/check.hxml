# Typecheck the OpenFL examples against the library (no window, no native compile).
# Run from the repo root:  haxe examples/check.hxml
# Requires (local .haxelib):  lime, openfl, hxcpp
-cp src
-cp examples/calculator
-cp examples/gallery
-cp examples/snip
-cp examples/notepad
-cp examples/notepad-mobile
-lib lime
-lib openfl
-lib hxcpp
Gallery
Calculator
Snip
Notepad
NotepadMobile
-cpp examples/bin/check
--no-output
