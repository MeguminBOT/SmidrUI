<?xml version="1.0" encoding="utf-8"?>
<project>
	<meta title="SmiðrUI Small Example" package="com.meguminbot.smidr.small" version="0.1.0" company="MeguminBOT" />

	<!--
		The smallest thing that draws and reacts to input. Build from the repo root:
		  lime test examples/small/project.xml windows
		  lime build examples/small/project.xml html5       (static web build -> bin/html5/bin)
		Swap `windows` for `mac`, `linux`, `html5`, `hl`, etc.
	-->
	<app main="SmallExample" file="SmallExample" path="bin" />
	<window width="420" height="260" fps="60" background="#121214" vsync="true" resizable="true" />

	<source path="../../src" />
	<source path="." />

	<haxelib name="openfl" />

	<!-- optional embedded font (falls back to a default font when absent); build with -Dassets -->
	<assets path="../assets" rename="assets" if="assets" />
</project>
